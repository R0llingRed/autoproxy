{
  "proxy_source": {
    "type": "openbao",
    "base_url": "https://127.0.0.1:8200",
    "token": "${OPENBAO_TOKEN}",
    "mount": "secret",
    "read_path": "external/proxies",
    "import_prefix": "external/proxies",
    "ca_cert_path": "${OPENBAO_CA_CERT_PATH:-}",
    "timeout": 10.0
  },
  "sub2api": {
    "base_url": "http://127.0.0.1:8080",
    "token": "${SUB2API_TOKEN:-}",
    "email": "${SUB2API_EMAIL:-}",
    "password": "${SUB2API_PASSWORD:-}",
    "login_path": "/api/v1/auth/login",
    "list_path": "/api/v1/admin/proxies",
    "create_path": "/api/v1/admin/proxies",
    "timezone": "Asia/Shanghai",
    "timeout": 10.0
  },
  "clash": {
    "write_mode": "yaml",
    "base_proxy_name": "hs2-US",
    "managed_group_name": "AUTO-CHAIN",
    "managed_proxy_prefix": "auto-chain-",
    "listener_start_port": 7892,
    "listener_host": "127.0.0.1",
    "config_path": "${CLASH_VERGE_HOME:-.}/clash-verge.yaml",
    "reload_after_write": false,
    "controller_url": "http://127.0.0.1:9090",
    "reload_force": true,
    "restart_after_write": true,
    "restart_strategy": "mihomo",
    "mihomo_executable": "D:/Program Files/Clash Verge/verge-mihomo.exe",
    "mihomo_home": "${CLASH_VERGE_HOME:-.}",
    "restart_wait_seconds": 2.0,
    "timeout": 10.0
  },
  "adspower": {
    "base_url": "http://127.0.0.1:50325",
    "api_key": "${ADSPOWER_API_KEY:-}",
    "timeout": 10.0
  },
  "browser": "adspower",
  "camoufox": {
    "profiles_dir": "data/camoufox/profiles",
    "templates_dir": "data/camoufox/templates",
    "bindings_path": "data/camoufox/bindings.json",
    "headless": false,
    "geoip": true,
    "humanize": true,
    "start_url": "https://www.browserscan.net",
    "timeout": 30.0,
    "window": "${CAMOUFOX_WINDOW:-1280x720}",
    "timezone": "${CAMOUFOX_TIMEZONE:-}"
  },
  "report_base_dir": "docs"
}

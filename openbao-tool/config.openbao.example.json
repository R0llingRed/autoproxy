{
  "proxy_source": {
    "type": "openbao",
    "base_url": "${OPENBAO_BASE_URL:-https://127.0.0.1:8200}",
    "token": "${OPENBAO_TOKEN}",
    "mount": "secret",
    "read_path": "external/proxies",
    "import_prefix": "external/proxies",
    "ca_cert_path": "${OPENBAO_CA_CERT_PATH:-}",
    "timeout": 10.0
  }
}
